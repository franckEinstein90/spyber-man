<main class="dashboard">
  <header>
    <h1>{{title}}</h1>
  </header>

  <section class="crawl-form">
    <h2>New Crawl</h2>
    <form id="crawl-form">
      <input type="url" id="crawl-url" placeholder="https://example.com" required />
      <button type="submit">Crawl</button>
    </form>
  </section>

  <section class="log-panel">
    <h2>Live Log</h2>
    <ul id="log-list"></ul>
  </section>
</main>
